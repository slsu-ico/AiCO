{
  "name": "ico-services-messenger-chatbot",
  "version": "0.1.0",
  "description": "Facebook Messenger chatbot trial for SLSU ICO Citizen's Charter services.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "migrate": "node src/db/migrate.js",
    "enable-rls": "node scripts/enable-rls.js",
    "seed": "node src/db/seed.js",
    "start": "node src/server.js",
    "ci": "npm run lint && npm test",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:migrate": "docker compose run --rm app npm run migrate",
    "docker:seed": "docker compose run --rm app npm run seed",
    "test": "node --test",
    "lint": "eslint src test scripts api",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.8.3"
  }
}
